package main

import (
	"fmt"
	"os"

	"github.com/jefflinse/clic"
)

func main() {
	app, err := clic.NewApp([]byte(`{{.SpecData}}`))
	if err != nil {
		fmt.Fprintf(os.Stderr, "clic: failed to instantiate app: %s", err.Error())
		os.Exit(1)
	}

	args := []string{}
	if len(os.Args) > 1 {
		args = append(args, os.Args[1:]...)
	}

	// the app reports its own errors via cobra; exit non-zero without re-reporting
	if err := app.Run(args); err != nil {
		os.Exit(1)
	}
}
